# ── Required ────────────────────────────────────────────────────────────────
JWT_SECRET=""
JWT_REFRESH_SECRET=""
TMDB_API_KEY=""           # v3 API key — used as ?api_key= fallback
DB_HOST=""
DB_USER=""
DB_PASSWORD=""
DB_NAME=""

# ── Optional (shown with defaults) ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGINS=*
DB_PORT=3306
LOG_LEVEL=info

TMDB_READ_ACCESS_TOKEN="" # v4 Bearer token — preferred over TMDB_API_KEY when set

# Public base URL of this server — used for Universal Links in password-reset emails.
# On Railway: set to https://watchd.up.railway.app
# Locally: http://localhost:3000 (emails log to console anyway when SMTP_HOST is empty)
APP_URL=https://watchd.app

# ── SMTP (leave SMTP_HOST empty to log emails to console instead of sending) ─
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=noreply@watchd.app

# ── APNs Push Notifications ──────────────────────────────────────────────────
APNS_KEY_ID=""            # 10-char Key ID from Apple Developer Portal
APNS_TEAM_ID=""           # 10-char Team ID
APNS_PRIVATE_KEY=""       # Base64-encoded .p8 contents (no newlines):
                          #   base64 -i AuthKey_XXXXXXXXXX.p8 | tr -d '\n'
APNS_PRODUCTION=false     # false = sandbox (Xcode device), true = TestFlight/App Store
                          # WARNING: combining a sandbox key with true fails silently

# ── Security tuning ──────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12          # bcrypt cost factor (default 12); niedriger nur für Tests

# ── Dev utilities ────────────────────────────────────────────────────────────
# WATCHD_APPLY_SCHEMA=1   # Auto-apply src/db/schema.sql on dev start (drops all data!)
