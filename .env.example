# ── Required ────────────────────────────────────────────────────────────────
JWT_SECRET=""
JWT_REFRESH_SECRET=""
TMDB_API_KEY=""           # v3 API key — used as ?api_key= fallback
DB_HOST=""
DB_USER=""
DB_PASSWORD=""
DB_NAME=""

# ── Optional (shown with defaults) ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGINS=*
DB_PORT=3306
LOG_LEVEL=info

TMDB_READ_ACCESS_TOKEN="" # v4 Bearer token — preferred over TMDB_API_KEY when set

# Public base URL of this server — used for Universal Links in password-reset emails.
# On Railway: set to https://watchd.up.railway.app
# Locally: http://localhost:3000 (emails log to console anyway when SMTP_HOST is empty)
APP_URL=https://watchd.app

# ── SMTP (leave SMTP_HOST empty to log emails to console instead of sending) ─
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=noreply@watchd.app

# ── APNs Push Notifications ──────────────────────────────────────────────────
APNS_KEY_ID=""            # 10-char Key ID from Apple Developer Portal
APNS_TEAM_ID=""           # 10-char Team ID
APNS_PRIVATE_KEY=""       # Base64-encoded .p8 contents (no newlines):
                          #   base64 -i AuthKey_XXXXXXXXXX.p8 | tr -d '\n'
APNS_PRODUCTION=false     # false = sandbox (Xcode device), true = TestFlight/App Store
                          # WARNING: combining a sandbox key with true fails silently

# ── Apple Sign In ────────────────────────────────────────────────────────────
# Native iOS only: APPLE_SERVICES_ID must be the Bundle ID (com.milinkovic.watchd),
# NOT a Services ID. Apple sets aud=bundleId in the identity token for native apps.
# Services IDs are only used for web/JS flows.
# Key: create a Sign in with Apple key (.p8) under Certificates, IDs & Profiles → Keys.
APPLE_SERVICES_ID=""        # Bundle ID of the iOS app — e.g. com.milinkovic.watchd
APPLE_TEAM_ID=""            # 10-char Team ID (same as APNs team)
APPLE_KEY_ID=""             # 10-char Key ID for the Sign-in-with-Apple key
APPLE_PRIVATE_KEY=""        # Base64-encoded .p8 contents (no newlines):
                            #   base64 -i AuthKey_XXXXXXXXXX.p8 | tr -d '\n'

# ── Google Sign In ───────────────────────────────────────────────────────────
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# → Create credentials → OAuth 2.0 Client ID → Application type: iOS
# The iOS client ID is used as the token audience (aud) claim — no secret needed.
# Verification uses Google's public JWKS endpoint, no backend secret required.
GOOGLE_CLIENT_ID_IOS=""   # iOS OAuth 2.0 client ID — e.g. 123456789-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=""   # Web client ID (optional — for future web/Android support)

# ── Security tuning ──────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12          # bcrypt cost factor (default 12); niedriger nur für Tests

# ── Dev utilities ────────────────────────────────────────────────────────────
# WATCHD_APPLY_SCHEMA=1   # Auto-apply src/db/schema.sql on dev start (drops all data!)
